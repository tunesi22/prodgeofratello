# GEO Platform — Environment Variables
# Copy file ini ke .env dan isi semua values
# JANGAN commit .env ke git

# ─── LLM APIs ───────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
PERPLEXITY_API_KEY=

# ─── Database ───────────────────────────────
MONGODB_URI=mongodb://localhost:27017/geo-platform

# ─── Queue ──────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth (Clerk) ───────────────────────────
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# ─── Email (Resend) ─────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# ─── Payment ────────────────────────────────
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── App ────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ─── Scan config ────────────────────────────
QUERY_REPEAT_COUNT=5        # berapa kali tiap prompt di-query per model
MAX_CONCURRENT_JOBS=3       # max parallel LLM calls di BullMQ
